# ============================================================================
# Anthropic API
# ============================================================================
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================================
# Meta Cloud API (WhatsApp)
# ============================================================================
# Verify token: any secret string you choose (used during webhook setup)
META_VERIFY_TOKEN=your_secret_verify_token_here

# Permanent system user access token from Meta Business Platform
META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxx

# WhatsApp Business Account phone number ID (from Meta Business Platform)
META_PHONE_NUMBER_ID=1234567890123456

# ============================================================================
# Raunk's Phone Number
# ============================================================================
# E.164 format (starts with +, country code, no spaces/dashes)
# Example: +919876543210
RAUNAK_PHONE=+919XXXXXXXXXX

# ============================================================================
# Google APIs
# ============================================================================
# Path to OAuth2 credentials JSON (from Google Cloud Console)
GOOGLE_CREDENTIALS_FILE=data/google_credentials.json

# Path to token file (auto-created after first OAuth flow)
GOOGLE_TOKEN_FILE=data/google_token.json

# ============================================================================
# External APIs
# ============================================================================
# OpenWeatherMap API key (free tier available)
OPENWEATHER_API_KEY=...

# NewsAPI.org API key (free tier available)
NEWS_API_KEY=...

# ============================================================================
# Database
# ============================================================================
# PostgreSQL connection string with asyncpg driver
# Format: postgresql+asyncpg://username:password@host:port/database
DATABASE_URL=postgresql+asyncpg://nova:password@localhost/nova_db

# ============================================================================
# Application Settings
# ============================================================================
MAX_CONVERSATION_HISTORY=50
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Transcription backend: "whisper" (default, free) or "sarvam" (regional languages)
TRANSCRIPTION_BACKEND=whisper
